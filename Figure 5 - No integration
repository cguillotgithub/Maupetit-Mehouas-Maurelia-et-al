```{r merge}
# Read CSVs (genes as rows, barcodes as columns)
datSBC1 <- read.table(csv_sbc1, sep = ",", header = TRUE, row.names = 1, check.names = FALSE)
datSBC3 <- read.table(csv_sbc3, sep = ",", header = TRUE, row.names = 1, check.names = FALSE)
datSBC7 <- read.table(csv_sbc7, sep = ",", header = TRUE, row.names = 1, check.names = FALSE)

# Create Seurat objects
SBC1 <- CreateSeuratObject(counts = data.frame(datSBC1, check.names = FALSE),
                           min.cells = min_cells, min.features = min_features_create, project = "SBC1")
SBC3 <- CreateSeuratObject(counts = data.frame(datSBC3, check.names = FALSE),
                           min.cells = min_cells, min.features = min_features_create, project = "SBC3")
SBC7 <- CreateSeuratObject(counts = data.frame(datSBC7, check.names = FALSE),
                           min.cells = min_cells, min.features = min_features_create, project = "SBC7")


merged_72H <- merge(SBC1, y = c(SBC3, SBC7),
                    add.cell.ids = c("SBC1", "SBC3", "SBC7"),
                    project = "combined_72H")



merged_72H[["percent.mt"]] <- PercentageFeatureSet(merged_72H, pattern = mt_pattern)

# For plots only (0–100)
merged_72H$percent.mt.pct <- 100 * merged_72H$percent.mt

# Sanity checks
table(merged_72H$orig.ident)
summary(merged_72H$percent.mt)
```


