## Drop SBC “genes” from RNA assay (if present)

```{r drop_sbc}
all_features <- rownames(merged_f)
drop_features <- grep(drop_feature_pattern, all_features, value = TRUE)

if (length(drop_features) > 0) {
  merged_f <- subset(merged_f, features = setdiff(all_features, drop_features))
  cat("Dropped features:", paste(drop_features, collapse = ", "), "\n")
} else {
  cat("No features matched drop_feature_pattern =", drop_feature_pattern, "\n")
}
```

## Standard Seurat workflow (no integration)

```{r seurat_workflow}
pca_npcs <- 50
dims_neighbors <- 1:50
dims_umap <- 1:20

merged_f <- NormalizeData(merged_f)
merged_f <- FindVariableFeatures(merged_f, selection.method = "vst", nfeatures = 1500)


merged_f <- ScaleData(merged_f, features = VariableFeatures(merged_f))

merged_f <- RunPCA(merged_f, npcs = pca_npcs)
ElbowPlot(merged_f)

merged_f <- FindNeighbors(merged_f, reduction = "pca", dims = dims_neighbors)
merged_f <- FindClusters(
  merged_f,
  resolution = cluster_resolution,
  random.seed = 1
)


merged_f <- RunUMAP(
  merged_f,
  reduction = "pca",
  dims = dims_umap,
  n.neighbors = umap_neighbors,
  seed.use = 1
)

```


