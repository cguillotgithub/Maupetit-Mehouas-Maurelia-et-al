## Cluster composition test — match original (p < 0.05, no FDR)

```{r cluster_composition_test, fig.width=10, fig.height=5}
n_samples <- dplyr::n_distinct(merged_f$orig.ident)
expected_prop <- 1 / n_samples

df <- merged_f@meta.data %>%
  as.data.frame() %>%
  dplyr::count(seurat_clusters, orig.ident) %>%
  dplyr::group_by(seurat_clusters) %>%
  dplyr::mutate(prop = n / sum(n)) %>%
  dplyr::ungroup()

clusters_extreme_SBC1 <- df %>%
  dplyr::filter(
    orig.ident == "SBC1",
    prop <= expected_prop * 0.5 | prop >= expected_prop * 1.5
  ) %>%
  dplyr::pull(seurat_clusters)

pvals <- df %>%
  dplyr::group_by(seurat_clusters) %>%
  dplyr::summarise(
    p.value = suppressWarnings(chisq.test(n, p = rep(expected_prop, n_samples))$p.value),
    .groups = "drop"
  )

df <- df %>% dplyr::left_join(pvals, by = "seurat_clusters")

df_filtered <- df %>%
  dplyr::filter(seurat_clusters %in% clusters_extreme_SBC1, p.value < 0.05)

p_comp <- ggplot(df_filtered, aes(x = seurat_clusters, y = prop, fill = orig.ident)) +
  geom_col(position = "fill") +
  geom_text(
    data = df_filtered %>% dplyr::distinct(seurat_clusters, p.value),
    aes(x = seurat_clusters, y = 1.05, label = paste0("p=", signif(p.value, 3))),
    inherit.aes = FALSE,
    size = 3
  ) +
  scale_fill_manual(values = c("SBC1"="navy","SBC3"="gold","SBC7"="firebrick")) +
  scale_y_continuous(labels = percent_format()) +
  labs(
    y = "Proportion of cells",
    x = "Cluster",
    fill = "Sample",
    title = "Clusters where SBC1 proportion deviates ≥50% from expected (p < 0.05)"
  ) +
  theme_minimal()

p_comp

ggsave(
  filename = file.path(out_dir, "cluster_composition_flagged_p005.pdf"),
  plot = p_comp,
  width = 10, height = 5
)
```


