sub_clusters <- levels(Idents(sub_seu))

deg_sub_list <- list()

for (cl in sub_clusters) {
  
  cat("Subcluster:", cl, "\n")
  
  cells_cl <- WhichCells(sub_seu, idents = cl)
  sub <- subset(sub_seu, cells = cells_cl)
  
  # Make sure the cluster has enough cells for each comparison
  cond_vec <- factor(as.character(sub@meta.data[[condition_col]]))
  Idents(sub) <- cond_vec
  conditions_present <- levels(Idents(sub))
  
  # SBC3 vs SBC1
  if (all(c("SBC1", "SBC3") %in% conditions_present)) {
    n_SBC1 <- sum(sub@meta.data[[condition_col]] == "SBC1")
    n_SBC3 <- sum(sub@meta.data[[condition_col]] == "SBC3")
    
    if (n_SBC1 >= 3 & n_SBC3 >= 3) {
      deg_3 <- FindMarkers(
        sub, ident.1 = "SBC3", ident.2 = "SBC1",
        assay = "RNA", logfc.threshold = 0.25, min.pct = 0.1
      )
      deg_3$gene <- rownames(deg_3)
      deg_3$subcluster <- cl
      deg_3$comparison <- "SBC3_vs_SBC1"
      deg_sub_list[[paste0(cl, "_SBC3")]] <- deg_3
    } else {
      cat("Skipping SBC3 vs SBC1 in subcluster", cl, "- too few cells\n")
    }
  }
  
  # SBC7 vs SBC1
  if (all(c("SBC1", "SBC7") %in% conditions_present)) {
    n_SBC1 <- sum(sub@meta.data[[condition_col]] == "SBC1")
    n_SBC7 <- sum(sub@meta.data[[condition_col]] == "SBC7")
    
    if (n_SBC1 >= 3 & n_SBC7 >= 3) {
      deg_7 <- FindMarkers(
        sub, ident.1 = "SBC7", ident.2 = "SBC1",
        assay = "RNA", logfc.threshold = 0.25, min.pct = 0.1
      )
      deg_7$gene <- rownames(deg_7)
      deg_7$subcluster <- cl
      deg_7$comparison <- "SBC7_vs_SBC1"
      deg_sub_list[[paste0(cl, "_SBC7")]] <- deg_7
    } else {
      cat("Skipping SBC7 vs SBC1 in subcluster", cl, "- too few cells\n")
    }
  }
}

