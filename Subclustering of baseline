get_cluster_column <- function(seu, obj_name) {
  md_cols <- colnames(seu@meta.data)
  
  if (obj_name == "baseline" && "seurat_clusters" %in% md_cols) {
    return("seurat_clusters")
  }
  
  if (grepl("^rpca_", obj_name) && "integrated_snn_res.0.18" %in% md_cols) {
    return("integrated_snn_res.0.18")
  }
  
  if (grepl("^harmony_", obj_name) && "SCT_snn_res.0.18" %in% md_cols) {
    return("SCT_snn_res.0.18")
  }
  
  if ("seurat_clusters" %in% md_cols) {
    return("seurat_clusters")
  }
  
  stop(paste("No suitable cluster column found for", obj_name))
}

get_fc_column <- function(marker_df) {
  fc_col <- preferred_fc_cols[preferred_fc_cols %in% colnames(marker_df)][1]
  if (is.na(fc_col)) stop("Could not find a logFC column in marker table.")
  fc_col
}

# =========================================================
# 5. Top 5 markers per cluster
# =========================================================
top_markers_list <- list()

for (i in seq_len(nrow(files_df))) {
  obj_name  <- files_df$obj_name[i]
  file_path <- files_df$path[i]
  
  cat("\nProcessing:", obj_name, "\n")
  
  seu <- readRDS(file_path)
  DefaultAssay(seu) <- "RNA"
  
  seu <- tryCatch(JoinLayers(seu), error = function(e) seu)
  
  cluster_col <- get_cluster_column(seu, obj_name)
  Idents(seu) <- cluster_col
  
  markers <- FindAllMarkers(
    seu,
    assay = "RNA",
    only.pos = TRUE,
    min.pct = min_pct_onlypos,
    logfc.threshold = logfc_onlypos
  )
  
  if (nrow(markers) == 0) next
  
  fc_col <- get_fc_column(markers)
  
  markers$gene_use <- if ("gene" %in% colnames(markers)) markers$gene else rownames(markers)
  
  tmp <- markers %>%
    mutate(
      gene = gene_use,
      cluster = as.character(cluster),
      object = obj_name,
      source_type = ifelse(obj_name == "baseline", "baseline", "integration")
    ) %>%
    arrange(cluster, desc(.data[[fc_col]]), desc(pct.1), p_val_adj) %>%
    group_by(object, source_type, cluster) %>%
    slice_head(n = top_n_markers) %>%
    mutate(rank_within_cluster = row_number()) %>%
    ungroup() %>%
    select(object, source_type, cluster, rank_within_cluster, gene, all_of(fc_col), pct.1, pct.2, p_val_adj)
  
  top_markers_list[[obj_name]] <- tmp
  
  rm(seu, markers, tmp)
  gc()
}

