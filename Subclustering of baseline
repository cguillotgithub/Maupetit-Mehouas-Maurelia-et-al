# =========================================================
# 2. Preprocess: normalization, variable features, scaling
# =========================================================
DefaultAssay(sub_seu) <- "RNA"
sub_seu <- NormalizeData(sub_seu)
sub_seu <- FindVariableFeatures(sub_seu, selection.method = "vst", nfeatures = 2000)
sub_seu <- ScaleData(sub_seu, features = rownames(sub_seu))

# =========================================================
# 3. Run PCA
# =========================================================
sub_seu <- RunPCA(sub_seu, features = VariableFeatures(sub_seu))

# =========================================================
# 4. Find neighbors and clusters (subclusters)
# =========================================================
