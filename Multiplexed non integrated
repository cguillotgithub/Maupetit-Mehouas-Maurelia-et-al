```

## Parameters

```{r p1_params}


out_dir <- "results/fig5_no_integration"
dir.create(out_dir, recursive = TRUE, showWarnings = FALSE)

# Input CSVs (starting from raw matrices)
csv_sbc1 <- "DEFINE_PATH"
csv_sbc3 <- "DEFINE_PATH"
csv_sbc7 <- "DEFINE_PATH"


#SBC1 = WT, SBC = 0,5mM HCys, SBC = 19 HCys
samples_keep <- c("SBC1", "SBC3", "SBC7")

# QC thresholds
min_cells <- 10
min_features_create <- 100

# mt pattern
mt_pattern <- c(
  "ATP6","ATP8",
  "COX1","COX2","COX3",
  "CYTB",
  "ND1","ND2","ND3","ND4","ND4L","ND5","ND6"
)

max_percent_mt <- 25
min_nFeature <- 1000
max_nFeature <- 10000

# Dimensionality / clustering
pca_npcs         <- 50
dims_neighbors   <- 1:20
dims_umap        <- 1:20
umap_neighbors   <- 50
cluster_resolution <- 0.2


# Remove SBC features from RNA assay
drop_feature_pattern <- "SBC"

# Composition test settings (keep if you want later)
focus_sample <- "SBC1"
deviation_factor <- 0.5
alpha <- 0.05


```


```{r p1_merge}
# Read CSVs (genes as rows, barcodes as columns)
datSBC1 <- read.table(csv_sbc1, sep = ",", header = TRUE, row.names = 1, check.names = FALSE)
datSBC3 <- read.table(csv_sbc3, sep = ",", header = TRUE, row.names = 1, check.names = FALSE)
datSBC7 <- read.table(csv_sbc7, sep = ",", header = TRUE, row.names = 1, check.names = FALSE)

# Create Seurat objects
SBC1 <- CreateSeuratObject(counts = data.frame(datSBC1, check.names = FALSE),
                           min.cells = min_cells, min.features = min_features_create, project = "SBC1")
SBC3 <- CreateSeuratObject(counts = data.frame(datSBC3, check.names = FALSE),
                           min.cells = min_cells, min.features = min_features_create, project = "SBC3")
SBC7 <- CreateSeuratObject(counts = data.frame(datSBC7, check.names = FALSE),
                           min.cells = min_cells, min.features = min_features_create, project = "SBC7")

# Merge (exactly like your original)
merged_72H <- merge(SBC1, y = c(SBC3, SBC7),
                    add.cell.ids = c("SBC1", "SBC3", "SBC7"),
                    project = "combined_72H")



merged_72H[["percent.mt"]] <- PercentageFeatureSet(merged_72H, features = mt_pattern)


# Sanity checks
table(merged_72H$orig.ident)
summary(merged_72H$percent.mt)
```


## QC plots (before filtering)

```{r p1_qc_before, fig.height=4, fig.width=12}
merged <- merged_72H
VlnPlot(merged, features = c("nFeature_RNA", "nCount_RNA", "percent.mt"), ncol = 3)
```



## Filter cells

```{r p1_filter}
merged_f <- subset(
  merged,
  subset = percent.mt < max_percent_mt &
    nFeature_RNA > min_nFeature &
    nFeature_RNA < max_nFeature
)

table(merged_f$orig.ident)
```


````{r p1_doublet removal}
library(SingleCellExperiment)
library(scDblFinder)

DefaultAssay(merged_f) <- "RNA"
merged_f <- JoinLayers(merged_f)

sce <- as.SingleCellExperiment(merged_f)
sce <- scDblFinder(sce, samples = sce$orig.ident)

merged_f$scDblFinder.class <- colData(sce)$scDblFinder.class
merged_f$scDblFinder.score <- colData(sce)$scDblFinder.score

table(merged_f$scDblFinder.class)

merged_f <- subset(merged_f, subset = scDblFinder.class == "singlet")

saveRDS(merged_f, file.path(out_dir, "Seurat_noint_merged_singlets.rds"))
cat("\nCells per sample (QC-filtered, before doublet removal):\n")
print(table(sce$orig.ident))  # same cells as merged_f before subsetting singlets

cat("\nCells per sample (singlets, after doublet removal):\n")
print(table(merged_f$orig.ident))

````


