

# Part 1 — Baseline / non-integrated 

```{r p1_setup, include=FALSE}
knitr::opts_chunk$set(echo = TRUE, message = FALSE, warning = FALSE)
set.seed(1)

library(Seurat)
library(dplyr)
library(tidyr)
