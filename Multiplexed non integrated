```{r p1_umap_custom_layered, fig.width=7, fig.height=6}
# Detect reduction and get coordinates
red <- if ("umap" %in% Reductions(merged_f)) "umap" else "pca"
emb <- Embeddings(merged_f, red)

# Build plotting df with fixed legend order
df <- data.frame(
  x = emb[, 1],
  y = emb[, 2],
  sample = factor(merged_f$orig.ident[rownames(emb)],
                  levels = c("SBC1", "SBC3", "SBC7"))
)

p_umap_layered <- ggplot() +
  geom_point(
    data = df[df$sample %in% c("SBC3", "SBC7"), ],
    aes(x = x, y = y, color = sample),
    size = 0.6, alpha = 0.5
  ) +
  geom_point(
    data = df[df$sample == "SBC1", ],
    aes(x = x, y = y, color = sample),
    size = 0.6, alpha = 1
  ) +
  scale_color_manual(
    values = c("SBC1" = "navy", "SBC3" = "gold", "SBC7" = "firebrick"),
    breaks = c("SBC1", "SBC3", "SBC7"),
    name = "Sample"
  ) +
  coord_equal() +
  theme_classic() +
  labs(
    x = paste(toupper(red), "1"),
    y = paste(toupper(red), "2"),
    title = "orig.ident"
  )

p_umap_layered

```
